---
const { title = 'Ronny 的開源回憶錄', description = '十幾年來的公民科技開源旅程' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" />
</head>
<body class="bg-stone-50 text-stone-800 font-sans min-h-screen">
  <header class="border-b border-stone-200 bg-white sticky top-0 z-10">
    <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-6 text-sm">
      <a href={`${base}/`} class="font-bold text-base text-stone-900 hover:text-indigo-600 transition-colors">
        Ronny 的開源旅程
      </a>
      <div class="flex gap-5 ml-auto">
        <a href={`${base}/timeline`} class="text-stone-600 hover:text-indigo-600 transition-colors">時間軸</a>
        <a href={`${base}/topics`} class="text-stone-600 hover:text-indigo-600 transition-colors">主題分類</a>
        <a href={`${base}/g0v-contributions`} class="text-stone-600 hover:text-indigo-600 transition-colors">g0v 參與</a>
        <a href={`${base}/hackathons`} class="text-stone-600 hover:text-indigo-600 transition-colors">黑客松</a>
        <a href="https://github.com/ronnywang" target="_blank" rel="noopener" class="text-stone-600 hover:text-indigo-600 transition-colors">GitHub ↗</a>
      </div>
    </nav>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <slot />
  </main>

  <footer class="border-t border-stone-200 mt-16 py-8 text-center text-sm text-stone-400">
    <p>由 <a href="https://github.com/ronnywang" class="underline hover:text-stone-600">ronnywang</a> 整理 · 使用 Claude AI 輔助撰寫</p>
  </footer>
</body>
</html>
