---
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoCard from '../components/RepoCard.astro';
import { getAllStories } from '../lib/stories.js';

const stories = getAllStories();
const featured = stories.filter(s => s.stars >= 5).slice(0, 6);
const total = stories.length;

// 統計
const totalStars = stories.reduce((s, r) => s + (r.stars || 0), 0);
const years = stories.map(s => s.date?.slice(0, 4)).filter(Boolean);
const yearRange = years.length ? `${Math.min(...years)} – ${Math.max(...years)}` : '';
const topics = new Set(stories.flatMap(s => Array.isArray(s.topics) ? s.topics : []));
---

<BaseLayout>
  <!-- Hero -->
  <section class="py-12 border-b border-stone-200 mb-10">
    <h1 class="text-3xl font-bold text-stone-900 mb-3">Ronny 的開源回憶錄</h1>
    <p class="text-stone-500 text-lg max-w-2xl mb-8">
      十幾年來參與 <a href="https://g0v.tw" target="_blank" class="text-indigo-600 underline">g0v 公民科技</a>，
      做了很多亂七八糟的開源工具。這裡收錄了每個專案背後的故事。
    </p>

    {total > 0 ? (
      <div class="flex flex-wrap gap-6 text-center">
        <div class="bg-white border border-stone-200 rounded-xl px-6 py-4 min-w-[120px]">
          <div class="text-3xl font-bold text-indigo-600">{total}</div>
          <div class="text-sm text-stone-500 mt-1">篇故事</div>
        </div>
        <div class="bg-white border border-stone-200 rounded-xl px-6 py-4 min-w-[120px]">
          <div class="text-3xl font-bold text-amber-500">{totalStars}</div>
          <div class="text-sm text-stone-500 mt-1">GitHub Stars</div>
        </div>
        {yearRange && (
          <div class="bg-white border border-stone-200 rounded-xl px-6 py-4 min-w-[120px]">
            <div class="text-xl font-bold text-stone-700">{yearRange}</div>
            <div class="text-sm text-stone-500 mt-1">年份跨度</div>
          </div>
        )}
        <div class="bg-white border border-stone-200 rounded-xl px-6 py-4 min-w-[120px]">
          <div class="text-3xl font-bold text-emerald-600">{topics.size}</div>
          <div class="text-sm text-stone-500 mt-1">主題分類</div>
        </div>
      </div>
    ) : (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 max-w-xl">
        <p class="text-amber-800 font-medium mb-2">尚未有故事</p>
        <p class="text-amber-700 text-sm">請先執行資料收集和訪談腳本：</p>
        <pre class="text-xs bg-amber-100 rounded p-3 mt-2">npm run fetch-repos
npm run fetch-readmes
npm run interview</pre>
      </div>
    )}
  </section>

  <!-- Featured stories -->
  {featured.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-bold text-stone-800 mb-5">精選故事</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {featured.map(s => <RepoCard story={s} />)}
      </div>
    </section>
  )}

  <!-- Recent stories -->
  {stories.length > 0 && (
    <section>
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xl font-bold text-stone-800">最新故事</h2>
        <a href={`${import.meta.env.BASE_URL}/timeline`} class="text-sm text-indigo-600 hover:underline">查看全部時間軸 →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {stories.slice(0, 9).map(s => <RepoCard story={s} />)}
      </div>
    </section>
  )}
</BaseLayout>
