---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

const hackathonData = JSON.parse(
  readFileSync(join(process.cwd(), 'data', 'g0v-hackathon-data.json'), 'utf-8')
);
const allHackathons = JSON.parse(
  readFileSync(join(process.cwd(), 'data', 'g0v-hackathons-list.json'), 'utf-8')
);
const summitData = JSON.parse(
  readFileSync(join(process.cwd(), 'data', 'g0v-summit-data.json'), 'utf-8')
);
const summitYears = Object.keys(summitData).sort((a, b) => Number(b) - Number(a));

// Build hackathon name lookup
const hackNameMap: Record<number, string> = {};
for (const h of allHackathons) {
  hackNameMap[h.num] = h.name;
}

const base = import.meta.env.BASE_URL;

const RONNY = ['ronny', 'ronnywang', '王向榮'];
function isRonny(name: string | undefined) {
  if (!name) return false;
  return RONNY.some(r => name.toLowerCase().includes(r));
}

// Collect all Ronny entries
interface Entry {
  hackathonId: string;
  num: number;
  date: string;
  hackathonName: string;
  type: 'proposal' | 'lightning' | 'report';
  entry: any;
}

const entries: Entry[] = [];

for (const [key, h] of Object.entries(hackathonData) as any) {
  for (const p of (h.proposals || [])) {
    if (isRonny(p.presenter)) {
      entries.push({ hackathonId: key, num: h.num, date: h.date, hackathonName: h.name || hackNameMap[h.num] || '', type: 'proposal', entry: p });
    }
  }
  for (const p of (h.lightning || [])) {
    if (isRonny(p.presenter)) {
      entries.push({ hackathonId: key, num: h.num, date: h.date, hackathonName: h.name || hackNameMap[h.num] || '', type: 'lightning', entry: p });
    }
  }
  for (const p of (h.reports || [])) {
    if (isRonny(p.presenter)) {
      entries.push({ hackathonId: key, num: h.num, date: h.date, hackathonName: h.name || hackNameMap[h.num] || '', type: 'report', entry: p });
    }
  }
}

entries.sort((a, b) => b.date.localeCompare(a.date));

// Group by hackathon
const byHackathon: Record<string, Entry[]> = {};
for (const e of entries) {
  if (!byHackathon[e.hackathonId]) byHackathon[e.hackathonId] = [];
  byHackathon[e.hackathonId].push(e);
}

const hackathonKeys = Object.keys(byHackathon).sort((a, b) => {
  const da = byHackathon[a][0].date;
  const db = byHackathon[b][0].date;
  return db.localeCompare(da);
});

const typeLabel = { proposal: '提案', lightning: '短講', report: '成果報告' };
const typeColor = {
  proposal: 'bg-indigo-50 border-indigo-200 text-indigo-600',
  lightning: 'bg-amber-50 border-amber-200 text-amber-700',
  report: 'bg-emerald-50 border-emerald-200 text-emerald-700',
};
const typeIcon = { proposal: '🚀', lightning: '⚡', report: '📊' };

const proposalCount = entries.filter(e => e.type === 'proposal').length;
const lightningCount = entries.filter(e => e.type === 'lightning').length;
const reportCount = entries.filter(e => e.type === 'report').length;
---

<BaseLayout title="Ronny 在 g0v 大松的參與紀錄">
  <div class="mb-8">
    <a href={`${base}/timeline`} class="text-sm text-stone-400 hover:text-indigo-500 mb-4 inline-block">← 時間軸</a>
    <h1 class="text-3xl font-bold text-stone-900 mb-3">g0v 大松參與紀錄</h1>
    <p class="text-stone-500 max-w-2xl leading-relaxed mb-4">
      從 g0v-hackathon-data.json 資料集中，整理出 Ronny（ronnywang / 王向榮）在歷次 g0v 黑客松中的提案、短講與成果報告。
    </p>
    <div class="flex flex-wrap gap-3 text-sm">
      <span class="px-3 py-1 bg-stone-800 text-white rounded-full font-mono">{hackathonKeys.length} 場大松</span>
      <span class="px-3 py-1 bg-indigo-50 border border-indigo-200 text-indigo-700 rounded-full">🚀 {proposalCount} 提案</span>
      <span class="px-3 py-1 bg-amber-50 border border-amber-200 text-amber-700 rounded-full">⚡ {lightningCount} 短講</span>
      <span class="px-3 py-1 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-full">📊 {reportCount} 成果報告</span>
    </div>
  </div>

  {/* g0v Summit 參與 */}
  <div class="mb-10">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-violet-700">🌐 g0v Summit 參與</h2>
      <a href={`${base}/events/g0v-summit`} class="text-sm text-violet-500 hover:text-violet-700 transition-colors">
        查看詳細頁面 →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-3">
      {summitYears.map(year => {
        const s = summitData[year];
        const hasRonny = s.ronny.length > 0;
        return (
          <a
            href={`${base}/events/g0v-summit`}
            class={`block border rounded-xl p-4 hover:shadow-sm transition-all ${
              hasRonny ? 'border-violet-200 bg-violet-50 hover:border-violet-400' : 'border-stone-200 bg-stone-50 hover:border-stone-300 opacity-70'
            }`}
          >
            <div class="flex items-center gap-2 mb-2">
              <span class={`text-base font-bold ${hasRonny ? 'text-violet-700' : 'text-stone-500'}`}>
                {year}
              </span>
              {hasRonny && (
                <span class="text-[10px] bg-amber-100 border border-amber-300 text-amber-700 px-1.5 py-0.5 rounded font-semibold">
                  Ronny
                </span>
              )}
            </div>
            <div class="text-xs text-stone-500 mb-1">
              {s.city}{s.location && s.location !== s.city ? ` · ${s.location.split('・')[0]}` : ''}
            </div>
            {hasRonny ? (
              <div class="space-y-1">
                {s.ronny.map((r: any) => (
                  <div class="text-xs text-violet-700 leading-tight">🎤 {r.title}</div>
                ))}
              </div>
            ) : (
              <div class="text-xs text-stone-400 italic">觀眾參與</div>
            )}
          </a>
        );
      })}
    </div>
  </div>

  <div class="space-y-6">
    {hackathonKeys.map(key => {
      const hackEntries = byHackathon[key];
      const first = hackEntries[0];
      return (
        <div class="border border-stone-200 rounded-xl overflow-hidden">
          {/* Hackathon header */}
          <div class="bg-stone-50 px-5 py-3 flex items-center justify-between border-b border-stone-200">
            <div class="flex items-center gap-3">
              <a href={`${base}/events/g0v-hackathon/th${first.num}n`}
                class="text-sm font-mono bg-amber-100 border border-amber-300 text-amber-800 px-2 py-0.5 rounded hover:bg-amber-200 transition-colors">
                第{first.num}n
              </a>
              <div>
                <span class="text-sm font-semibold text-stone-700">{first.hackathonName}</span>
                <span class="text-xs text-stone-400 ml-2">{first.date}</span>
              </div>
            </div>
            <div class="flex gap-1">
              {hackEntries.filter(e => e.type === 'proposal').length > 0 && (
                <span class="text-xs px-1.5 py-0.5 bg-indigo-50 border border-indigo-200 text-indigo-600 rounded">
                  🚀×{hackEntries.filter(e => e.type === 'proposal').length}
                </span>
              )}
              {hackEntries.filter(e => e.type === 'lightning').length > 0 && (
                <span class="text-xs px-1.5 py-0.5 bg-amber-50 border border-amber-200 text-amber-700 rounded">
                  ⚡×{hackEntries.filter(e => e.type === 'lightning').length}
                </span>
              )}
              {hackEntries.filter(e => e.type === 'report').length > 0 && (
                <span class="text-xs px-1.5 py-0.5 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded">
                  📊×{hackEntries.filter(e => e.type === 'report').length}
                </span>
              )}
            </div>
          </div>

          {/* Entries */}
          <div class="divide-y divide-stone-100">
            {hackEntries.map(e => (
              <div class="px-5 py-3 flex items-start gap-3">
                <span class={`text-xs px-2 py-0.5 rounded border font-medium shrink-0 mt-0.5 ${typeColor[e.type]}`}>
                  {typeIcon[e.type]} {typeLabel[e.type]}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-medium text-stone-800 truncate">
                    {e.entry.project || e.entry.topic || '（未命名）'}
                  </div>
                  {e.entry.topic && e.entry.topic !== e.entry.project && (
                    <div class="text-xs text-stone-500 mt-0.5 truncate">{e.entry.topic}</div>
                  )}
                  {e.entry.brief && (
                    <div class="text-xs text-stone-400 mt-0.5">{e.entry.brief}</div>
                  )}
                </div>
                <div class="flex gap-2 shrink-0">
                  {e.entry.hackmd && (
                    <a href={e.entry.hackmd} target="_blank" class="text-xs text-indigo-400 hover:text-indigo-600">
                      📝
                    </a>
                  )}
                  {e.entry.slides && (
                    <a href={e.entry.slides} target="_blank" class="text-xs text-indigo-400 hover:text-indigo-600">
                      🖼
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <div class="mt-10 p-5 bg-stone-50 rounded-xl border border-stone-200 text-sm text-stone-500">
    <p class="font-semibold text-stone-700 mb-2">關於這份資料</p>
    <p>資料來源：<a href="https://github.com/ronnywang/ronny-github/blob/main/data/g0v-hackathon-data.json" class="text-indigo-500 hover:underline">g0v-hackathon-data.json</a>，整理自 g0v 歷次大松議程試算表（ethercalc-cache.g0v.tw 及 Google Sheets）。</p>
    <p class="mt-1">涵蓋 hackath11n（2014）至 hackath72n（2026），共 54 次大松，747 提案 / 185 短講 / 495 成果報告。</p>
    <p class="mt-1">早期大松（hackath1n～10n）及部分場次因資料格式不統一，尚未納入。</p>
  </div>
</BaseLayout>
