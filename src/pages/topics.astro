---
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoCard from '../components/RepoCard.astro';
import { getAllStories, getAllTopics } from '../lib/stories.js';

const stories = getAllStories();
const topics = getAllTopics(stories);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="主題分類 — Ronny 的開源回憶錄">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-stone-900 mb-2">主題分類</h1>
    <p class="text-stone-500">按主題瀏覽，看同一脈絡下的多次嘗試與演進</p>
  </div>

  {topics.length === 0 && (
    <p class="text-stone-400 text-center py-16">尚無故事，請先執行訪談腳本</p>
  )}

  <!-- Topic quick nav -->
  {topics.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-10">
      {topics.map(({ topic, stories: ts }) => (
        <a href={`#topic-${topic}`}
           class="px-3 py-1 bg-white border border-stone-200 rounded-full text-sm text-stone-600 hover:border-indigo-400 hover:text-indigo-600 transition-colors">
          {topic}
          <span class="ml-1 text-stone-400">{ts.length}</span>
        </a>
      ))}
    </div>
  )}

  <!-- Topic sections -->
  {topics.map(({ topic, stories: ts }) => (
    <section id={`topic-${topic}`} class="mb-12 scroll-mt-20">
      <div class="flex items-center gap-4 mb-5">
        <h2 class="text-xl font-bold text-stone-800">{topic}</h2>
        <span class="text-sm text-stone-400">{ts.length} 個專案</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {ts.map(s => <RepoCard story={s} />)}
      </div>
    </section>
  ))}
</BaseLayout>
