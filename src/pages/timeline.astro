---
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoCard from '../components/RepoCard.astro';
import { getAllStories, groupByYear } from '../lib/stories.js';
import { readFileSync } from 'fs';
import { join } from 'path';

const stories = getAllStories();
const grouped = groupByYear(stories);
const base = import.meta.env.BASE_URL;

// 讀取 g0v 黑客松清單
const allHackathons = JSON.parse(
  readFileSync(join(process.cwd(), 'data', 'g0v-hackathons-list.json'), 'utf-8')
);

// 讀取自辦活動場次
const eventSessions = JSON.parse(
  readFileSync(join(process.cwd(), 'data', 'event-sessions.json'), 'utf-8')
);

// g0v 黑客松依年份分組
const hackathonsByYear = {};
for (const h of allHackathons) {
  if (!hackathonsByYear[h.year]) hackathonsByYear[h.year] = [];
  hackathonsByYear[h.year].push(h);
}

// 自辦活動依年份分組：{ year: { eventKey: [sessions] } }
const eventsByYear = {};
for (const [key, ev] of Object.entries(eventSessions)) {
  for (const s of ev.sessions) {
    const year = parseInt(s.date.slice(0, 4));
    if (!eventsByYear[year]) eventsByYear[year] = {};
    if (!eventsByYear[year][key]) eventsByYear[year][key] = [];
    eventsByYear[year][key].push({ ...s, label: ev.label, color: ev.color });
  }
}

// 找出故事有關聯的黑客松編號
const linkedTerms = new Set();
for (const s of stories) {
  if (s.term !== undefined && s.term !== null) linkedTerms.add(Number(s.term));
}

// 合併所有年份
const allYears = Array.from(new Set([
  ...grouped.map(g => parseInt(g.year)),
  ...Object.keys(hackathonsByYear).map(y => parseInt(y)),
  ...Object.keys(eventsByYear).map(y => parseInt(y)),
])).sort((a, b) => b - a);

// 顏色 map
const colorMap = {
  emerald: 'bg-emerald-50 border-emerald-300 text-emerald-700',
  rose:    'bg-rose-50 border-rose-300 text-rose-700',
  purple:  'bg-purple-50 border-purple-300 text-purple-700',
};
---

<BaseLayout title="時間軸 — Ronny 的開源回憶錄">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-stone-900 mb-2">時間軸</h1>
    <p class="text-stone-500 mb-3">從最新到最舊，看開源旅程的演進脈絡</p>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-stone-500">
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded font-mono bg-indigo-50 border border-indigo-200 text-indigo-500">第0n</span>
        g0v 黑客松
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded font-mono bg-amber-100 border border-amber-400 text-amber-800 font-semibold">第0n</span>
        有我的專案的黑客松
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded font-mono bg-emerald-50 border border-emerald-300 text-emerald-700">第0n</span>
        數位韌性松
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded font-mono bg-rose-50 border border-rose-300 text-rose-700">第0n</span>
        國會松
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded font-mono bg-purple-50 border border-purple-300 text-purple-700">第0n</span>
        黑魔法防禦松
      </span>
    </div>
  </div>

  <div class="relative">
    {allYears.map(year => {
      const yearHackathons = hackathonsByYear[year] || [];
      const yearEvents = eventsByYear[year] || {};
      const yearStories = grouped.find(g => g.year === String(year))?.stories || [];
      const hasAnyContent = yearHackathons.length > 0 || Object.keys(yearEvents).length > 0 || yearStories.length > 0;
      if (!hasAnyContent) return null;

      return (
        <section class="mb-10">
          {/* 年份標題 */}
          <div class="flex items-center gap-4 mb-3">
            <div class="text-2xl font-bold text-indigo-600 w-16 shrink-0">{year}</div>
            <div class="flex-1 h-px bg-stone-200"></div>
            <div class="text-xs text-stone-400 flex gap-3">
              {yearHackathons.length > 0 && <span>{yearHackathons.length} 次大松</span>}
              {yearStories.length > 0 && <span>{yearStories.length} 個故事</span>}
            </div>
          </div>

          <div class="pl-20 space-y-1.5 mb-4">
            {/* g0v 黑客松列 */}
            {yearHackathons.length > 0 && (
              <div class="flex flex-wrap items-center gap-1.5">
                <span class="text-xs text-stone-400 w-20 shrink-0">g0v 黑客松</span>
                <div class="flex flex-wrap gap-1">
                  {yearHackathons.map(h => {
                    const isLinked = linkedTerms.has(h.num);
                    return (
                      <span
                        title={`${h.date}　${h.name}`}
                        class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-mono cursor-default select-none border
                          ${isLinked
                            ? 'bg-amber-100 border-amber-400 text-amber-800 font-semibold'
                            : 'bg-indigo-50 border-indigo-200 text-indigo-500'
                          }`}
                      >
                        第{h.num}n
                      </span>
                    );
                  })}
                </div>
              </div>
            )}

            {/* 自辦活動列 */}
            {Object.entries(yearEvents).map(([key, sessions]) => (
              <div class="flex flex-wrap items-center gap-1.5">
                <span class="text-xs text-stone-400 w-20 shrink-0">{sessions[0].label}</span>
                <div class="flex flex-wrap gap-1">
                  {sessions.map(s => (
                    <span
                      title={s.date}
                      class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-mono cursor-default select-none border ${colorMap[s.color] || 'bg-stone-50 border-stone-300 text-stone-600'}`}
                    >
                      第{s.num}n
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>

          {/* 故事卡片 */}
          {yearStories.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 pl-20">
              {yearStories.map(s => <RepoCard story={s} />)}
            </div>
          )}
        </section>
      );
    })}
  </div>
</BaseLayout>
