---
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoCard from '../components/RepoCard.astro';
import { getAllStories, groupByYear } from '../lib/stories.js';
import { readFileSync } from 'fs';
import { join } from 'path';

const stories = getAllStories();
const grouped = groupByYear(stories);
const base = import.meta.env.BASE_URL;

// 讀取 g0v 黑客松清單
const hackathonsRaw = readFileSync(join(process.cwd(), 'data', 'g0v-hackathons-list.json'), 'utf-8');
const allHackathons = JSON.parse(hackathonsRaw);

// 以年份分組黑客松
const hackathonsByYear = {};
for (const h of allHackathons) {
  if (!hackathonsByYear[h.year]) hackathonsByYear[h.year] = [];
  hackathonsByYear[h.year].push(h);
}

// 找出故事有關聯的黑客松編號（從 frontmatter 的 term 欄位）
const linkedTerms = new Set();
for (const s of stories) {
  if (s.term !== undefined && s.term !== null) linkedTerms.add(Number(s.term));
}

// 合併年份清單（黑客松 + 故事）
const allYears = Array.from(new Set([
  ...grouped.map(g => parseInt(g.year)),
  ...Object.keys(hackathonsByYear).map(y => parseInt(y))
])).sort((a, b) => b - a);
---

<BaseLayout title="時間軸 — Ronny 的開源回憶錄">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-stone-900 mb-2">時間軸</h1>
    <p class="text-stone-500 mb-3">從最新到最舊，看開源旅程的演進脈絡</p>
    <div class="flex flex-wrap items-center gap-4 text-xs text-stone-500">
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-mono bg-indigo-50 border border-indigo-200 text-indigo-600">第0n</span>
        g0v 黑客松
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-mono bg-amber-100 border border-amber-400 text-amber-800 font-semibold">第0n</span>
        有我的專案的黑客松
      </span>
    </div>
  </div>

  <div class="relative">
    {allYears.map(year => {
      const yearHackathons = hackathonsByYear[year] || [];
      const yearStories = grouped.find(g => g.year === String(year))?.stories || [];

      return (
        <section class="mb-10">
          {/* 年份標題 */}
          <div class="flex items-center gap-4 mb-3">
            <div class="text-2xl font-bold text-indigo-600 w-16 shrink-0">{year}</div>
            <div class="flex-1 h-px bg-stone-200"></div>
            <div class="text-xs text-stone-400 flex gap-3">
              {yearHackathons.length > 0 && <span>{yearHackathons.length} 次黑客松</span>}
              {yearStories.length > 0 && <span>{yearStories.length} 個故事</span>}
            </div>
          </div>

          {/* 黑客松標記列 */}
          {yearHackathons.length > 0 && (
            <div class="pl-20 mb-4 flex flex-wrap gap-1.5">
              {yearHackathons.map(h => {
                const isLinked = linkedTerms.has(h.num);
                return (
                  <span
                    title={`${h.date}　${h.name}`}
                    class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-mono cursor-default select-none
                      ${isLinked
                        ? 'bg-amber-100 border border-amber-400 text-amber-800 font-semibold'
                        : 'bg-indigo-50 border border-indigo-200 text-indigo-500'
                      }`}
                  >
                    第{h.num}n
                  </span>
                );
              })}
            </div>
          )}

          {/* 故事卡片 */}
          {yearStories.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 pl-20">
              {yearStories.map(s => <RepoCard story={s} />)}
            </div>
          )}
        </section>
      );
    })}
  </div>
</BaseLayout>
