---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  const allHackathons = JSON.parse(
    readFileSync(join(process.cwd(), 'data', 'g0v-hackathons-list.json'), 'utf-8')
  );
  const eventSessions = JSON.parse(
    readFileSync(join(process.cwd(), 'data', 'event-sessions.json'), 'utf-8')
  );

  // g0v 大松
  const g0vPath = {
    params: { type: 'g0v-hackathon' },
    props: {
      title: 'g0v 黑客松',
      subtitle: '台灣零時政府雙月黑客松',
      description: 'g0v 社群從 2012 年起每兩個月舉辦一次黑客松，以「人、坑、松」為核心，去中心化運作，至今已超過 70 次。',
      color: 'indigo',
      sessions: allHackathons.map(h => ({
        num: h.num,
        date: h.date,
        name: h.name,
        url: null,
        notes: null,
      })),
    },
  };

  // 自辦活動
  const eventPaths = Object.entries(eventSessions).map(([key, ev]) => ({
    params: { type: key },
    props: {
      title: ev.label,
      subtitle: '',
      description: '',
      color: ev.color,
      sessions: ev.sessions.map(s => ({
        num: s.num,
        date: s.date,
        name: s.name || null,
        url: s.url || null,
        notes: s.notes || null,
        location: s.location || null,
      })),
    },
  }));

  return [g0vPath, ...eventPaths];
}

const { title, subtitle, description, color, sessions } = Astro.props;

const colorBadge = {
  indigo:  'bg-indigo-50 border-indigo-200 text-indigo-600',
  emerald: 'bg-emerald-50 border-emerald-300 text-emerald-700',
  rose:    'bg-rose-50 border-rose-300 text-rose-700',
  purple:  'bg-purple-50 border-purple-300 text-purple-700',
  orange:  'bg-orange-50 border-orange-300 text-orange-700',
  teal:    'bg-teal-50 border-teal-300 text-teal-700',
};
const colorHeader = {
  indigo:  'text-indigo-600',
  emerald: 'text-emerald-600',
  rose:    'text-rose-600',
  purple:  'text-purple-600',
  orange:  'text-orange-600',
  teal:    'text-teal-600',
};

// 依年份分組
const byYear: Record<number, typeof sessions> = {};
for (const s of sessions) {
  const y = parseInt(s.date.slice(0, 4));
  if (!byYear[y]) byYear[y] = [];
  byYear[y].push(s);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title={`${title} — Ronny 的開源回憶錄`}>
  <div class="mb-8">
    <a href="/ronny-github/timeline" class="text-sm text-stone-400 hover:text-indigo-500 mb-4 inline-block">← 時間軸</a>
    <h1 class={`text-3xl font-bold mb-1 ${colorHeader[color] || 'text-stone-900'}`}>{title}</h1>
    {subtitle && <p class="text-stone-500 text-sm mb-2">{subtitle}</p>}
    {description && <p class="text-stone-600 max-w-2xl">{description}</p>}
    <p class="text-stone-400 text-sm mt-3">共 {sessions.length} 場</p>
  </div>

  <div class="space-y-10">
    {years.map(year => (
      <section>
        <h2 class="text-xl font-bold text-stone-700 mb-3 border-b border-stone-100 pb-2">{year}</h2>
        <div class="space-y-2">
          {byYear[year].map(s => (
            <div class="flex items-start gap-3 py-2 border-b border-stone-50 hover:bg-stone-50 rounded px-2 -mx-2 transition-colors">
              <span class={`shrink-0 inline-flex items-center px-2 py-0.5 rounded border text-xs font-mono ${colorBadge[color] || 'bg-stone-50 border-stone-200 text-stone-500'}`}>
                第{s.num}n
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 flex-wrap">
                  <span class="text-sm text-stone-500">{s.date}</span>
                  {s.name && <span class="text-sm text-stone-700">{s.name}</span>}
                  {s.location && (
                    <span class="text-xs text-stone-400">
                      📍 {s.location}
                    </span>
                  )}
                </div>
                {(s.url || s.notes) && (
                  <div class="flex gap-3 mt-1">
                    {s.url && (
                      <a href={s.url} target="_blank" class="text-xs text-indigo-500 hover:underline">
                        報名頁面 ↗
                      </a>
                    )}
                    {s.notes && (
                      <a href={s.notes} target="_blank" class="text-xs text-indigo-500 hover:underline">
                        共筆 ↗
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
