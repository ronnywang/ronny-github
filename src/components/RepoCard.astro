---
const { story, compact = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const startYear = story.date ? story.date.slice(0, 4) : '';
const updatedYear = story.updated ? story.updated.slice(0, 4) : '';
const endLabel = updatedYear >= '2025' ? 'now' : updatedYear;
const yearRange = !startYear ? '' :
  (!endLabel || endLabel === startYear) ? startYear :
  `${startYear}–${endLabel}`;
const topics = Array.isArray(story.topics) ? story.topics.slice(0, 3) : [];
---

<a href={`${base}/repo/${story.slug}`}
   class={`block bg-white border border-stone-200 rounded-xl p-5 hover:border-indigo-400 hover:shadow-md transition-all group ${compact ? 'py-3' : ''}`}>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <h3 class={`font-mono font-semibold text-stone-900 group-hover:text-indigo-700 transition-colors truncate ${compact ? 'text-sm' : 'text-base'}`}>
          {story.slug}
        </h3>
        {story.isFork && (
          <span class="text-xs px-1.5 py-0.5 bg-stone-100 text-stone-500 rounded shrink-0">fork</span>
        )}
      </div>
      {story.title && story.title !== story.slug && (
        <p class={`text-stone-600 ${compact ? 'text-xs' : 'text-sm'} mb-1`}>{story.title}</p>
      )}
      {!compact && story.summary && (
        <p class="text-stone-500 text-sm line-clamp-2 mt-1">{story.summary}</p>
      )}
    </div>
    <div class="text-right text-xs text-stone-400 shrink-0">
      {yearRange && <div>{yearRange}</div>}
      {story.stars > 0 && <div class="text-amber-500">★ {story.stars}</div>}
    </div>
  </div>

  {!compact && topics.length > 0 && (
    <div class="flex flex-wrap gap-1 mt-3">
      {topics.map(t => (
        <span class="text-xs px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded-full">{t}</span>
      ))}
      {story.language && (
        <span class="text-xs px-2 py-0.5 bg-stone-100 text-stone-500 rounded-full">{story.language}</span>
      )}
    </div>
  )}
</a>
